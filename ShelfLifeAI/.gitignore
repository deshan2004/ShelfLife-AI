# ============================================
# 📦 NODE / NPM / YARN
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================
# 🛠️ BUILD OUTPUTS (Vite / React)
# ============================================
dist/
dist-ssr/
build/
.vite/
*.local

# ============================================
# 🔑 ENVIRONMENT VARIABLES (Sensitive)
# ============================================
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# ============================================
# 🔥 FIREBASE SECURITY (Sensitive - NEVER COMMIT!)
# ============================================
serviceAccountKey.json
*.key.json
*.pem
firebase-debug.log
firebase-debug.*.log

# ============================================
# 💻 IDE / EDITOR FILES
# ============================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================
# ☕ JAVA / ANDROID (if any mobile components)
# ============================================
*.class
*.jar
*.war
*.ear

# ============================================
# 🧪 TESTING / COVERAGE
# ============================================
coverage/
.nyc_output/
*.lcov
*.test-results

# ============================================
# 📊 LOGS & TEMP FILES
# ============================================
logs/
*.log
*.tmp
*.temp
.cache/
.temp/

# ============================================
# 🐍 PYTHON (if used for any scripts)
# ============================================
__pycache__/
*.py[cod]
*$py.class

# ============================================
# 🐳 DOCKER (if using)
# ============================================
docker-compose.override.yml
*.pid
*.seed
*.pid.lock

# ============================================
# 🧩 MISCELLANEOUS
# ============================================
*.tgz
*.gz
*.zip
*.rar
*.7z
.env.production
.env.development.local
.env.test.local